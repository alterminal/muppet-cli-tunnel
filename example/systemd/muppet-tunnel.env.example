# 環境變量配置文件
# 重要：請確保此文件的權限為 600 (僅所有者可讀寫)
# chmod 600 /home/ydc3148/alter/muppet-cli-tunnel/env/muppet-tunnel.env

# WebSocket 服務器 URL（可選，會覆蓋配置文件中的值）
# MUPPET_SERVER_URL=wss://www.alterminal.com/mcps/tunnels/websocket

# 隧道 ID
# MUPPET_ID=your-tunnel-id-here

# 密鑰（建議使用 systemd 環境文件而不是直接寫在配置文件中）
# MUPPET_SECRET_KEY=your-secret-key-here

# Node.js 環境
# NODE_ENV=production